#!/usr/bin/env bash
# tmux-repo-cmd-picker
#
# fzf picker for project-specific commands defined in
# .workspace/tmux-commands.toml inside the workspace directory. Parses the
# TOML [[command]] entries (name, run, cwd, description) without external
# dependencies. When a command is selected it opens a new tmux window named
# after the command, runs it there, and drops into an interactive shell when
# it finishes. Requires TMUX_WORKSPACE_STATE_DIR.
set -euo pipefail

STATE_DIR="${TMUX_WORKSPACE_STATE_DIR:?TMUX_WORKSPACE_STATE_DIR is required}"
INNER_SOCKET="/tmp/tmux-ws-$(printf '%s' "$STATE_DIR" | cksum | cut -d' ' -f1).sock"
WORKSPACE_DIR_FILE="$STATE_DIR/workspace_dir"
FIELD_SEP=$'\x1f'

if [ -n "${TMUX_WORKSPACE_DIR:-}" ]; then
  WORKSPACE_DIR="$TMUX_WORKSPACE_DIR"
elif [ -f "$WORKSPACE_DIR_FILE" ]; then
  WORKSPACE_DIR="$(cat "$WORKSPACE_DIR_FILE")"
else
  echo "No workspace dir found in TMUX_WORKSPACE_DIR or:"
  echo "  $WORKSPACE_DIR_FILE"
  exit 1
fi

COMMANDS_FILE="$WORKSPACE_DIR/.workspace/tmux-commands.toml"
if [ ! -f "$COMMANDS_FILE" ]; then
  echo "No repo command file found at:"
  echo "  $COMMANDS_FILE"
  exit 1
fi

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

unquote() {
  local value
  value="$(trim "$1")"
  if [[ "$value" == \"* && "$value" == *\" ]]; then
    value="${value:1:${#value}-2}"
  fi
  value="${value//\\\"/\"}"
  value="${value//\\\\/\\}"
  printf '%s' "$value"
}

append_command_row() {
  if [ -n "${current_name:-}" ] && [ -n "${current_run:-}" ]; then
    COMMAND_ROWS+=("${current_name}${FIELD_SEP}${current_run}${FIELD_SEP}${current_cwd:-}${FIELD_SEP}${current_desc:-}")
  fi
}

COMMAND_ROWS=()
current_name=""
current_run=""
current_cwd=""
current_desc=""

while IFS= read -r raw_line || [ -n "$raw_line" ]; do
  line="$(trim "$raw_line")"

  [ -n "$line" ] || continue
  [[ "$line" == \#* ]] && continue

  if [ "$line" = "[[command]]" ]; then
    append_command_row
    current_name=""
    current_run=""
    current_cwd=""
    current_desc=""
    continue
  fi

  key="${line%%=*}"
  value="${line#*=}"
  key="$(trim "$key")"
  value="$(unquote "$value")"
  value="${value//$'\t'/ }"
  value="${value//$'\n'/ }"

  case "$key" in
    name) current_name="$value" ;;
    run) current_run="$value" ;;
    cwd) current_cwd="$value" ;;
    description) current_desc="$value" ;;
  esac
done < "$COMMANDS_FILE"

append_command_row

if [ "${#COMMAND_ROWS[@]}" -eq 0 ]; then
  echo "No commands found in:"
  echo "  $COMMANDS_FILE"
  exit 1
fi

FZF_INPUT=()
for row in "${COMMAND_ROWS[@]}"; do
  IFS="$FIELD_SEP" read -r name run cwd desc <<< "$row"
  label="$name"
  if [ -n "$desc" ]; then
    label="$label [$desc]"
  fi
  FZF_INPUT+=("${label}${FIELD_SEP}${row}")
done

selection="$(
  printf '%s\n' "${FZF_INPUT[@]}" |
    fzf \
      --prompt="Repo command > " \
      --delimiter="$FIELD_SEP" \
      --with-nth=1 \
      --height=100% \
      --layout=reverse \
      --border \
      --header="$WORKSPACE_DIR"
)"

if [ -z "$selection" ]; then
  exit 1
fi

selection="${selection#*"$FIELD_SEP"}"
IFS="$FIELD_SEP" read -r name run cwd desc <<< "$selection"

target_cwd=""
if [ -n "$cwd" ]; then
  if [[ "$cwd" = /* ]]; then
    target_cwd="$cwd"
  else
    target_cwd="$WORKSPACE_DIR/$cwd"
  fi
else
  ACTIVE_WINDOW_ID="$(
    tmux -S "$INNER_SOCKET" list-windows -F '#{?window_active,#{window_id},}' |
      sed -n '/./{p;q;}'
  )"
  if [ -n "$ACTIVE_WINDOW_ID" ]; then
    target_cwd="$(
      tmux -S "$INNER_SOCKET" list-panes -t "$ACTIVE_WINDOW_ID" -F '#{?pane_active,#{pane_current_path},}' |
        sed -n '/./{p;q;}'
    )"
  fi
fi

shell_bin="${SHELL:-/bin/zsh}"
pane_command="$run; exec $(printf '%q' "$shell_bin") -l"

if [ -n "$target_cwd" ]; then
  tmux -S "$INNER_SOCKET" new-window -n "$name" -c "$target_cwd" \
    "$shell_bin" -c "$pane_command"
else
  tmux -S "$INNER_SOCKET" new-window -n "$name" \
    "$shell_bin" -c "$pane_command"
fi

tmux display-message "Opened: $name"
