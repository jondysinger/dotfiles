#!/usr/bin/env bash
# tmux-shell-picker
#
# fzf picker for switching between tmux windows in the current session.
# Displays each window by index and name (marking the active one), then
# switches focus to the selected window. Exits silently if no selection
# is made.
set -euo pipefail

selection="$(
  tmux list-windows -F "#{window_index}\t#{window_name}\t#{?window_active,current,}" |
    fzf \
      --prompt="Shell tab > " \
      --delimiter=$'\t' \
      --with-nth=1,2,3 \
      --layout=reverse \
      --border \
      --height=100%
)"

if [ -z "$selection" ]; then
  exit 0
fi

window_index="${selection%%$'\t'*}"
tmux select-window -t "$window_index"
