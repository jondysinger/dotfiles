#!/usr/bin/env bash
# tmux-nvim
#
# Start nvim listening on a Unix socket so other panes can send files to it.
# The socket path is written to $TMUX_WORKSPACE_STATE_DIR/nvim_server so that
# tmux-nvim-open can discover it. Intended to be launched by tmux-ws as the
# main editor pane in a workspace session.
set -euo pipefail

STATE_DIR="${TMUX_WORKSPACE_STATE_DIR:?TMUX_WORKSPACE_STATE_DIR is required}"
DIR="${TMUX_WORKSPACE_DIR:-$PWD}"
SERVER_FILE="$STATE_DIR/nvim_server"
SERVER_PATH="$STATE_DIR/nvim.sock"

mkdir -p "$STATE_DIR"
rm -f "$SERVER_PATH"
printf '%s\n' "$SERVER_PATH" > "$SERVER_FILE"

cd "$DIR"
exec nvim --listen "$SERVER_PATH"
